class Monster:
    def __init__(self, name='Люкан', power='15', hp='90'):
        self.name = name
        self.power = power
        self.hp = hp

    def mutate(self):
        self.power += 5
        print(f'{self.name} мутирует! Сила увеличина!')
        print(f'⚔️: {self.power}')

    def rets(self):
        self.hp += 10
        print(f'{self.name} отдыхает в склепе! Здоровье восстановленно!')
        print(f'❤️: {self.hp}')

m = Monster('Дракула', 15, 95)
m.mutate()
m.rets()
