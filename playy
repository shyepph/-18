import random


# ЭТАП 1
class Monster:


    def __init__(self, name, hp, dmg):
        self.__name = name
        self.__hp = hp
        self.__dmg = dmg

    def get_name(self):
        return self.__name

    def get_hp(self):
        return self.__hp

    def get_dmg(self):
        return self.__dmg

    def set_hp(self, value):
        if value < 0:
            self.__hp = 0
        else:
            self.__hp = value

    def is_alive(self):
        return self.__hp > 0

    def show_status(self):
        print(f"[{self.__name}] HP: {self.__hp}")

    def take_damage(self, damage):
        #СТАНДАРТ ПОЛУЧЕНИЯ УРОНА
        self.set_hp(self.get_hp() - damage)
        print(f"{self.get_name()} получает {damage} урона. HP: {self.get_hp()}")

    def attack_hunter(self, hunter):
        # АТАКА ОХОТНИКА
        hunter.set_hp(hunter.get_hp() - self.__dmg)
        print(f"{self.get_name()} атакует охотника! Урон: {self.__dmg}")


# ЭТАП 2
class Zombie(Monster):
    def __init__(self, name):
        super().__init__(name, 120, 10)

    def take_damage(self, damage):
        # зомби просто получает урон но с уникальным сообщением
        self.set_hp(self.get_hp() - damage)
        print(f"{self.get_name()} теряет конечность! Получено: {damage}. HP: {self.get_hp()}")


class Vampire(Monster):
    def __init__(self, name):
        super().__init__(name, 80, 15)

    def take_damage(self, damage):
        # ПОГЛОЩЕНИЕ 5 УРОНА
        absorbed = 5
        actual_damage = max(0, damage - absorbed)
        self.set_hp(self.get_hp() - actual_damage)
        print(f"{self.get_name()} поглощает {absorbed} урона! Получено: {actual_damage}. HP: {self.get_hp()}")


class Ghost(Monster):
    def __init__(self, name):
        super().__init__(name, 60, 20)

    def take_damage(self, damage):
        # 30% ШАНСА НА УКЛОНЕНИЕ
        if random.random() < 0.3:
            print(f"{self.get_name()} уклоняется от атаки! HP: {self.get_hp()}")
        else:
            self.set_hp(self.get_hp() - damage)
            print(f"{self.get_name()} получает {damage} урона. HP: {self.get_hp()}")


class Werewolf(Monster):
    def __init__(self, name):
        super().__init__(name, 100, 25)
        self.__transformed = False

    def take_damage(self, damage):
        self.set_hp(self.get_hp() - damage)
        print(f"{self.get_name()} получает {damage} урона. HP: {self.get_hp()}")

        # ПРИ HP < 50 ТРАНСФОРМИРУЕТСЯ
        if self.get_hp() < 50 and not self.__transformed:
            self.__transformed = True
            print(f"{self.get_name()} трансформируется в свою истинную форму! Сила увеличивается!")


