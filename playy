# ЭТАП 4
class Hunter:
    def __init__(self, name):
        self.__name = name
        self.__hp = 100
        self.__weapons = []

    def get_name(self):
        return self.__name

    def get_hp(self):
        return self.__hp

    def set_hp(self, value):
        if value < 0:
            self.__hp = 0
        else:
            self.__hp = value

    def add_weapon(self, weapon):
        self.__weapons.append(weapon)
        print(f"Оружие '{weapon.get_name()}' добавлено в арсенал!")

    def show_inventory(self):
        if not self.__weapons:
            print("Инвентарь пуст!")
            return

        print("\n=== Инвентарь охотника ===")
        for i, weapon in enumerate(self.__weapons, 1):
            print(f"{i}. {weapon.get_name()}")
        print("=" * 27)

    def attack(self, weapon_index, monster):
        if weapon_index < 1 or weapon_index > len(self.__weapons):
            print("Неверный индекс оружия!")
            return False

        weapon = self.__weapons[weapon_index - 1]
        print(f"\n{self.__name} атакует {monster.get_name()}!")
        weapon.use(monster)
        return True

    def is_alive(self):
        return self.__hp > 0

    def show_status(self):
        print(f"\n[{self.__name}] HP: {self.__hp}")


# ЭТАП 5
def run_game():
    print("=" * 60)
    print("ДОБРО ПОЖАЛОВАТЬ В СИМУЛЯТОР ОХОТЫ НА НЕЧИСТЬ!")
    print("=" * 60)

    # СОЗДАНИЕ ОХОТНИКА
    hunter = Hunter("Ван Хельсинг")
    print(f"\nОхотник {hunter.get_name()} готов к бою!")

    # ДОБАВЛЕНИЕ ОРУЖИЯ
    hunter.add_weapon(SilverSword())
    hunter.add_weapon(HolyWater())
    hunter.add_weapon(CrossbowBolt())
    hunter.show_inventory()

    # СОЗДАГИЕ МОНСТРОВ
    monsters = [
        Zombie("Зомби-страж"),
        Vampire("Граф Дракула"),
        Ghost("Призрак замка"),
        Werewolf("Оборотень")
    ]

    print("\n" + "=" * 60)
    print("МОНСТРЫ ПРИБЛИЖАЮТСЯ!")
    print("=" * 60)
    for monster in monsters:
        monster.show_status()

    # ИГРОВОЙ ЦИКЛ
    print("\n" + "=" * 60)
    print("БОЙ НАЧИНАЕТСЯ!")
    print("=" * 60)

    round_number = 1
    current_monster_index = 0

    while hunter.is_alive() and current_monster_index < len(monsters):
        monster = monsters[current_monster_index]

        print(f"\n{'=' * 60}")
        print(f"РАУНД {round_number} - Бой с {monster.get_name()}")
        print(f"{'=' * 60}")

        # АТАКА ОХОТНИКА
        hunter.show_status()
        monster.show_status()

        # ВЫБОР ОРУЖИЯ
        print("\nВыберите оружие для атаки:")
        hunter.show_inventory()

        while True:
            try:
                choice = int(input("Ваш выбор (номер оружия): "))
                if 1 <= choice <= 3:
                    break
                else:
                    print("Пожалуйста выберите номер от 1 до 3")
            except ValueError:
                print("Пожалуйста введите число!")

        hunter.attack(choice, monster)

        # ПРОВЕРКА ЖИВ ЛИ МОНСТР
        if not monster.is_alive():
            print(f"\n{monster.get_name()} повержен! Победа!")
            current_monster_index += 1
            round_number += 1
            continue

        # МОНСТР КОНТРАТАКУЕТ
        print(f"\n{monster.get_name()} контратакует!")
        monster.attack_hunter(hunter)

        # ПРОВЕРКА ЖИВ ЛИ ОХОТНИК
        if not hunter.is_alive():
            print(f"\n{monster.get_name()} победил охотника!")
            break

        round_number += 1

        # ПОКАЗ СТАТУСА ПОСЛЕ КАЖДОГО РАУНДА
        print(f"\n--- Статус после раунда {round_number - 1} ---")
        hunter.show_status()
        monster.show_status()

    # ИТОГ
    print("\n" + "=" * 60)
    print("ИТОГ БИТВЫ")
    print("=" * 60)

    if hunter.is_alive() and current_monster_index == len(monsters):
        print(f"ПОБЕДА! {hunter.get_name()} зачистил замок от всей нечисти!")
        print(f"Осталось здоровья: {hunter.get_hp()}")
    elif not hunter.is_alive():
        print("ПОРАЖЕНИЕ! Монстры одолели охотника...")
        print(f"Уничтожено монстров: {current_monster_index} из {len(monsters)}")
    else:
        print("Бой прерван... Судьба замка остаётся неизвестной.")

run_game()
