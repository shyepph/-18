class Inventory:


    def __init__(self, gold):
        self.__gold = gold

    def get_gold(self):
        return f'В кошельке {self.__gold} проклятых монет'

    def change_gold (self, amount):
        new_balance = self.__gold + amount

        if new_balance < 0:
            print ('Недостаточно золота для сделки')
        else:
            self.__gold = new_balance
            print('Сделка состоялась')


bag = Inventory (50)
print(bag.get_gold())
bag.change_gold(-30)
bag.change_gold(10)
print(bag.get_gold())
bag.change_gold(-100)
